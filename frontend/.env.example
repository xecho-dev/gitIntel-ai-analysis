# GitIntel 前端环境变量示例
# 复制此文件为 .env.local 并填入实际值

# ─── NextAuth (GitHub OAuth) ────────────────────────────────────────────────
# 在 https://github.com/settings/applications/new 创建 OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github (开发)
#                          或 https://your-domain.com/api/auth/callback/github (生产)
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"

# NextAuth 密钥 (生成: openssl rand -base64 32)
AUTH_SECRET="your-nextauth-secret-min-32-chars"

# 与后端 JWT_SECRET 保持一致（JWT 解密用）
JWT_SECRET="your-jwt-secret-same-as-backend"

# ─── Agent 服务 ───────────────────────────────────────────────────────────────
# 本地开发: http://localhost:8000
# 部署后: 替换为你的后端实际地址
NEXT_PUBLIC_API_URL=http://localhost:8000
