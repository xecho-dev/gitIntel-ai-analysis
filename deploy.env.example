# ============================================================
# GitIntel 部署环境变量
# ============================================================

# ── 公开变量（NEXT_PUBLIC_*）──────────────────────────────────
# 容器网络内：前端访问后端用 backend:8000
NEXT_PUBLIC_API_URL=http://backend:8000

# ── NextAuth v5 ────────────────────────────────────────────────
# 服务端密钥（必填）
AUTH_SECRET=******
# 站点地址（用于回调）
AUTH_URL=http://47.80.59.132
AUTH_TRUST_HOST=true

# NextAuth v4 兼容
NEXTAUTH_URL=http://47.80.59.132
NEXTAUTH_SECRET=******

# ── GitHub OAuth ────────────────────────────────────────────────
AUTH_GITHUB_ID=******
AUTH_GITHUB_SECRET=******

# ── Supabase（前端匿名请求用，公开）──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://******.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_******

# ── 后端环境变量 ────────────────────────────────────────────────
# GitHub 操作权限 Token（需要有 repo 权限的 Personal Access Token）
GITHUB_TOKEN=ghp_******

# OpenAI（Agent 层 LLM 调用）
OPENAI_API_KEY="sk-******"
OPENAI_MODEL="qwen-plus-2025-07-28"
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ── Token 消耗控制 ─────────────────────────────────────────────────
# 单次 LLM 输出最大 token 数（默认 1024）
# 减小此值可显著降低 token 消耗，建议范围 512~2048
MAX_OUTPUT_TOKENS=1024

# ReAct Explorer Agent 最大迭代轮数（默认 4，减少可降低 token）
EXPLORER_MAX_ITERATIONS=4

# ReAct Repo Loader 最大迭代轮数（默认 8，减少可降低 token）
REPO_LOADER_MAX_ITERATIONS=8

# 单次工具执行结果最大字符数（默认 2000，建议范围 1000~3000）
TOOL_RESULT_TRUNCATE=2000

SUPABASE_SERVICE_KEY=sb_secret_******

# 前端对外地址（后端 CORS 白名单用）
FRONTEND_URL=http://47.80.59.132

