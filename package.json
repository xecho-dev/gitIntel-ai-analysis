{
  "name": "gitintel-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:backend": "cd backend && .venv/bin/python3 -m pytest -v",
    "test:frontend": "pnpm --filter frontend test",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:admin": "pnpm --filter @gitintel/admin dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:admin": "pnpm --filter @gitintel/admin build",
    "dev:backend": "cd backend && export $(cat ../deploy.env | grep -v '^#' | grep -v '^$' | xargs) && .venv/bin/python3 -B -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "~5.8.2",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.0.4"
}
