# ============================================================
# GitIntel 后端环境变量
# ============================================================

# ── Supabase（必填，后端数据库操作需要 service role key）──────────
# SUPABASE_URL: 从 Supabase Dashboard → Settings → API 获取
SUPABASE_URL=https://*****.supabase.co
# SUPABASE_SERVICE_KEY: 从 Supabase Dashboard → Settings → API 获取（service_role key）
SUPABASE_SERVICE_KEY=sb_secret_*********

# ── Supabase 兼容变量（前端公开配置，仅供前端使用）──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://****.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_********

# ── 前端对外地址（后端 CORS 白名单用）───────────────────────────────
FRONTEND_URL=http://localhost:3000


# ── Chroma（RAG 向量存储，本地持久化）───────────────────────────────
# Chroma 数据持久化目录（默认 ./data/chroma）
CHROMA_DATA_DIR=./data/chroma

# Collection 名称（分离设计，不要混淆）
# gitintel_knowledge: RAG 知识库，存分析结果、建议、洞察（供检索生成用）
# gitintel_memory:    聊天记忆，存 AI 助手对话历史（按 session_id 隔离）
CHROMA_COLLECTION_KNOWLEDGE=gitintel_knowledge
CHROMA_COLLECTION_MEMORY=gitintel_memory
