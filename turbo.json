{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
  "build": {
    "dependsOn": ["^build"],
    "outputs": ["frontend/.next/**"]
    "inputs": ["frontend/**"]
  },
  "dev": {
    "cache": false,
    "persistent": true
  },
  "lint": {
    "dependsOn": ["^build"],
    "inputs": ["frontend/**"]
  }
  }
}
