# Agent 层开发规范（FastAPI + LangGraph）

## 项目结构

```
backend/
├── agents/              # 各 Agent 实现
│   ├── __init__.py
│   ├── base_agent.py    # Agent 基类（通用接口）
│   ├── architecture.py  # 架构分析 Agent
│   ├── quality.py        # 代码质量 Agent
│   ├── dependency.py     # 依赖风险 Agent
│   └── optimization.py  # 优化建议 Agent
├── graph/               # LangGraph 工作流
│   ├── __init__.py
│   ├── state.py          # SharedState 定义
│   └── analysis_graph.py # 主工作流编排
├── tools/               # Agent 可用工具
├── schemas/             # Pydantic 数据模型
│   ├── __init__.py
│   ├── request.py
│   └── response.py
├── main.py              # FastAPI 入口
├── pyproject.toml
└── requirements.txt
```

## Agent 设计原则

### 基类抽象
所有 Agent 继承 `BaseAgent`，统一工具调用和输出格式：

```python
# agents/base_agent.py
from abc import ABC, abstractmethod
from typing import AsyncGenerator, TypedDict

class AgentEvent(TypedDict):
    type: str        # "status" | "progress" | "result" | "error"
    agent: str       # agent name
    message: str | None
    percent: int | None
    data: dict | None

class BaseAgent(ABC):
    name: str

    @abstractmethod
    async def stream(self, repo_url: str, branch: str = "main") -> AsyncGenerator[AgentEvent, None]:
        """流式输出事件（SSE 用）"""
        ...

    async def run(self, repo_url: str, branch: str = "main") -> dict:
        """执行 Agent，返回结果字典"""
        result = None
        async for event in self.stream(repo_url, branch):
            if event["type"] == "result":
                result = event["data"]
        return result or {}
```

### Agent 实现示例

```python
# agents/architecture.py
from .base_agent import BaseAgent, AgentEvent
from typing import AsyncGenerator

class ArchitectureAgent(BaseAgent):
    name = "architecture"

    async def stream(self, repo_url: str, branch: str = "main") -> AsyncGenerator[AgentEvent, None]:
        yield AgentEvent(
            type="status", agent=self.name,
            message="正在扫描项目目录...", percent=10, data=None
        )
        tree = await self._scan_directory(repo_url)
        yield AgentEvent(
            type="progress", agent=self.name,
            message="目录扫描完成", percent=30, data=None
        )
        components = await self._parse_components(tree)
        yield AgentEvent(
            type="status", agent=self.name,
            message=f"解析到 {len(components)} 个组件", percent=60, data=None
        )
        result = await self._analyze_dependencies(components)
        yield AgentEvent(
            type="result", agent=self.name,
            message="架构分析完成", percent=100, data=result
        )
```

## LangGraph 工作流编排

### SharedState 定义
所有 Agent 共享同一个 State，所有结果存入其中：

```python
# graph/state.py
from typing import TypedDict, Optional

class AnalysisState(TypedDict):
    repo_url: str
    branch: str
    architecture_result: Optional[dict]
    quality_result: Optional[dict]
    dependency_result: Optional[dict]
    optimization_result: Optional[dict]
    errors: list[str]
```

### 工作流组装

```python
# graph/analysis_graph.py
import asyncio
import json
from typing import AsyncGenerator

from agents.architecture import ArchitectureAgent
from agents.quality import QualityAgent
from agents.dependency import DependencyAgent
from agents.optimization import OptimizationAgent


async def stream_analysis(repo_url: str, branch: str = "main") -> AsyncGenerator[str, None]:
    """并行执行四个 Agent，流式输出所有事件"""
    agents = [
        ArchitectureAgent(),
        QualityAgent(),
        DependencyAgent(),
        OptimizationAgent(),
    ]

    async def run_agent(agent) -> list:
        results = []
        async for event in agent.stream(repo_url, branch):
            results.append(event)
        return results

    # 并行执行所有 Agent
    all_results = await asyncio.gather(*[run_agent(a) for a in agents])

    # 按顺序 yield 每个 Agent 的事件
    for agent_results in all_results:
        for event in agent_results:
            yield f"data: {json.dumps(event)}\n\n"
    yield "data: [DONE]\n\n"
```

## FastAPI 接口

### SSE 流式端点

```python
# main.py
from fastapi import FastAPI
from fastapi.responses import StreamingResponse
from graph.analysis_graph import stream_analysis
from schemas.request import AnalyzeRequest

app = FastAPI(title="GitIntel Agent API", version="0.1.0")

@app.post("/api/analyze")
async def analyze(req: AnalyzeRequest):
    return StreamingResponse(
        stream_analysis(req.repo_url, req.branch),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "Connection": "keep-alive",
            "X-Accel-Buffering": "no",
        },
    )
```

### CORS 配置
允许前端 BFF 跨域调用：

```python
from fastapi.middleware.cors import CORSMiddleware

app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)
```

## 错误处理

```python
async def stream(self, repo_url: str, branch: str = "main") -> AsyncGenerator[AgentEvent, None]:
    try:
        yield AgentEvent(type="status", agent=self.name, message="启动中...", percent=0, data=None)
        result = await self._do_work(repo_url)
        yield AgentEvent(type="result", agent=self.name, message="完成", percent=100, data=result)
    except Exception as e:
        yield AgentEvent(
            type="error", agent=self.name,
            message=f"执行失败: {str(e)}", percent=0, data=None
        )
```

